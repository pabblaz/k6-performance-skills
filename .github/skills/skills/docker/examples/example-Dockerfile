FROM grafana/k6:0.54.0-with-browser

# Switch to root to install necessary packages and modify permissions
USER root

# Install dependencies (e.g., Python, curl, bash)
RUN apk add --no-cache \
    python3 \
    py3-pip \
    bash \
    curl \
    procps

WORKDIR /app

# Copy application files to the container
COPY . /app/

# Ensure scripts are executable
RUN chmod +x /app/infrastructure/run-test.sh

# ---- SECURITY BEST PRACTICES ----
# Create non-root user 'automator' for enhanced container security
RUN addgroup -S automator && adduser -S automator -G automator

# Set proper ownership and permissions for the 'automator' user
RUN chown -R automator:automator /app && \
    chmod -R 755 /app

# Switch to the non-root user before running instructions
USER automator

# Override default entrypoints if needed
ENTRYPOINT []

# Default command
CMD ["sh", "/app/infrastructure/run-test.sh"]
